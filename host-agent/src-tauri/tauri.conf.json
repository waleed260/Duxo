{
  "$schema": "https://raw.githubusercontent.com/nickel-org/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Duxo",
  "version": "0.1.0",
  "identifier": "dev.duxo.host",
  "build": {
    "frontendDist": "../html",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Duxo — Remote Desktop Host"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMedia": true
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://waleed260.github.io/Duxo/update.json"
      ],
      "pubkey": "CHANGE_ME_TO_YOUR_ED25519_PUBKEY"
    }
  }
}
